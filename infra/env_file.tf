# Writes a .env file in the project root with backend connection URLs.
# bench.py reads this via _make_env() to configure logstorm/qstorm.
#
# OPENAI_API_KEY is not managed here — set it in your shell environment
# or add it to .env manually after terraform apply.

resource "local_file" "dot_env" {
  filename        = "${path.module}/../.env"
  file_permission = "0600"

  content = join("\n", compact([
    "# Generated by terraform — do not edit manually",
    "# Re-run 'terraform apply' to regenerate after changes",
    "",
    "BACKEND_INSTANCE_TYPE=${var.instance_type}",
    length(aws_instance.qdrant) > 0 ? "QDRANT_URL=http://${aws_instance.qdrant[0].public_ip}:6334" : null,
    length(aws_instance.elasticsearch) > 0 ? "ELASTIC_URL=http://${aws_instance.elasticsearch[0].public_ip}:9200" : null,
    length(aws_instance.elasticsearch) > 0 ? "ELASTIC_USER=elastic" : null,
    length(aws_instance.elasticsearch) > 0 ? "ELASTIC_PASSWORD=${var.es_password}" : null,
    length(aws_instance.pgvector) > 0 ? "PGVECTOR_HOST=${aws_instance.pgvector[0].public_ip}" : null,
    length(aws_instance.pgvector) > 0 ? "PGVECTOR_USER=postgres" : null,
    length(aws_instance.pgvector) > 0 ? "PGVECTOR_PASSWORD=${var.pg_password}" : null,
    "",
  ]))
}
